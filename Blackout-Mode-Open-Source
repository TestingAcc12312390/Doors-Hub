local function _getGitAsset(url, fileName)
    if not isfile(fileName .. ".mp3") and string.find(fileName, ".mp3") then
        writefile(fileName .. ".mp3", game:HttpGet(url))
    elseif not isfile(fileName) then
        writefile(fileName, game:HttpGet(url))
    end

    local assetFunc = getcustomasset or getsynasset
    return assetFunc(string.find(fileName, ".mp3") and (fileName .. ".mp3") or fileName)
end

TextChatService.OnIncomingMessage = function(message)
    local properties = Instance.new("TextChatMessageProperties")

    if message.TextSource then
        local player = Players:GetPlayerByUserId(message.TextSource.UserId)

        if player then
            if player.Name == "TestingDoorsScrip" then
                properties.PrefixText = "<font color='#FFD700'>[Owner]</font> " .. (message.PrefixText or "")
            elseif player.Name == "kardindoorsgoat" then
                properties.PrefixText = "<font color='#00AAFF'>[Admin]</font> " .. (message.PrefixText or "")
            end
        end
    end

    return properties
end

local function ExecuteCommand(cmd, sender)
    print("SYNC EXECUTED:", cmd, "FROM:", sender)

    if cmd == "shadow_eyes" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Shadow-Eyes"))()
    elseif cmd == "insanity" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Insanity-Entity"))()
    elseif cmd == "fatality" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Fatality-Entity"))()
    elseif cmd == "nightmare_cease" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Nightmare-Cease"))()
    end
end

local function HookPlayer(player)
    player.Chatted:Connect(function(msg)
        if not AllowedPlayers[player.Name] then return end
        msg = tostring(msg)
        if string.sub(msg, 1, #PREFIX) ~= PREFIX then return end
        local cmd = string.sub(msg, #PREFIX + 1)
        if not COMMANDS[cmd] then return end
        ExecuteCommand(cmd, player.Name)
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    HookPlayer(player)
end

